DJANGO_SETTINGS_MODULE=core.settings.development
DEBUG=True
SECRET_KEY=replace-this-with-a-long-random-secret-key
DATABASE_URL=postgresql://fincore:fincore@localhost:5432/fincore
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
ACCESS_TOKEN_LIFETIME_MINUTES=30
REFRESH_TOKEN_LIFETIME_DAYS=7
ANON_THROTTLE_RATE=100/hour
USER_THROTTLE_RATE=1000/hour
AUTH_ANON_THROTTLE_RATE=20/hour
AUTH_USER_THROTTLE_RATE=60/hour
DEFAULT_FROM_EMAIL=no-reply@fincore.local
SERVER_EMAIL=no-reply@fincore.local
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_TIMEOUT=10
ENABLE_CLOUDINARY=False
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
LOG_LEVEL=INFO
SECURE_SSL_REDIRECT=False
USE_X_FORWARDED_HOST=True
SECURE_HSTS_SECONDS=31536000
